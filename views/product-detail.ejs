<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>

<body>
  <%- include("partials/header") %>

  <%
    const safeProduct = product || {};
    const safeName = safeProduct.name || "Produk Pilihan";
    const safeCategory = safeProduct.category || "Produk";
    const safeCategorySlug = safeProduct.categorySlug || "";
    const categoryUrl = safeCategorySlug ? `/kategori/${safeCategorySlug}` : "/produk";

    const mediaImages = Array.isArray(safeProduct.images) && safeProduct.images.length
      ? safeProduct.images.filter(Boolean)
      : [safeProduct.image || "https://via.placeholder.com/800x800?text=Teman+Belanja"];

    const safeShortDesc = safeProduct.shortDesc || "";
    const safeDesc = safeProduct.desc || "Produk ini layak dipertimbangkan untuk kebutuhan kamu.";
    const safeSuitableFor = safeProduct.suitableFor || "";
    const safePrice = typeof formatRupiah === "function"
      ? formatRupiah(safeProduct.price || 0)
      : ("Rp " + Number(safeProduct.price || 0).toLocaleString("id-ID"));

    const hasAffiliate = Boolean(safeProduct.affiliateUrl || safeProduct.sourceUrl);
  %>

  <section class="section container product-detail-page">
    <nav class="breadcrumb" aria-label="Breadcrumb" style="margin-bottom:18px;">
      <a href="/">Beranda</a>
      <span>/</span>
      <a href="/produk">Produk</a>
      <% if (safeCategorySlug) { %>
        <span>/</span>
        <a href="<%= categoryUrl %>"><%= safeCategory %></a>
      <% } %>
      <span>/</span>
      <span><%= safeName %></span>
    </nav>

    <div class="product-detail-grid">
      <div class="product-gallery-card">
        <div class="product-gallery">
          <div class="main-media">
            <img
              id="mainPreview"
              src="<%= mediaImages[0] %>"
              alt="<%= safeName %>"
              loading="lazy"
              onclick="openLightboxFromMain()"
            />
          </div>

          <% if (mediaImages.length > 1) { %>
            <div class="thumb-list">
              <% mediaImages.forEach((img, index) => { %>
                <button
                  type="button"
                  class="thumb-btn <%= index === 0 ? 'active' : '' %>"
                  onclick='changePreview(<%- JSON.stringify(img) %>, <%= index %>, this)'
                  aria-label="Lihat gambar <%= index + 1 %> <%= safeName %>"
                >
                  <img
                    src="<%= img %>"
                    alt="Gambar <%= index + 1 %> <%= safeName %>"
                    loading="lazy"
                  />
                </button>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>

      <div class="product-info-card">
        <div class="product-info">
          <div class="product-top-meta">
            <a href="<%= categoryUrl %>" class="pill"><%= safeCategory %></a>
          </div>

          <h1 class="product-title"><%= safeName %></h1>

          <% if (safeShortDesc) { %>
            <p class="short-desc"><%= safeShortDesc %></p>
          <% } %>

          <p class="price big"><%= safePrice %></p>

          <div class="quick-info-grid">
            <div class="quick-info-item">
              <span class="label">Kategori</span>
              <strong><%= safeCategory %></strong>
            </div>

            <% if (safeSuitableFor) { %>
              <div class="quick-info-item">
                <span class="label">Cocok Untuk</span>
                <strong><%= safeSuitableFor %></strong>
              </div>
            <% } %>

            <div class="quick-info-item">
              <span class="label">Status</span>
              <strong>Ready</strong>
            </div>
          </div>

          <div class="trust-points">
            <span>✅ Produk pilihan</span>
            <span>✅ Link aman</span>
          </div>

          <div class="buy-buttons">
            <% if (hasAffiliate) { %>
              <a
                class="btn-buy-main"
                target="_blank"
                rel="nofollow sponsored"
                href="/go/<%= safeProduct.id %>"
              >
                🛒 Beli Sekarang
              </a>
            <% } %>

            <a
              class="btn-buy-admin"
              target="_blank"
              rel="noopener noreferrer"
              href="https://wa.me/6285383481491?text=Halo%20admin%2C%20saya%20ingin%20dibantu%20produk%20ini%3A%20<%= encodeURIComponent(BASE_URL + '/produk/' + safeProduct.slug) %>"
            >
              💬 Tanya Admin
            </a>
          </div>

          <div class="product-description">
            <h2>Deskripsi Produk</h2>
            <p><%= safeDesc %></p>
          </div>

          <% if (safeProduct.benefits && safeProduct.benefits.length) { %>
            <div class="info-box">
              <h3>Kelebihan Produk</h3>
              <ul>
                <% safeProduct.benefits.forEach((item) => { %>
                  <li><%= item %></li>
                <% }) %>
              </ul>
            </div>
          <% } %>

          <% if (safeProduct.specs && safeProduct.specs.length) { %>
            <div class="info-box">
              <h3>Spesifikasi</h3>
              <ul>
                <% safeProduct.specs.forEach((item) => { %>
                  <li><%= item %></li>
                <% }) %>
              </ul>
            </div>
          <% } %>

          <div class="info-box">
            <h3>Lihat Kategori Serupa</h3>
            <p style="margin:0 0 14px;color:#555;line-height:1.8;">
              Jelajahi lebih banyak produk dalam kategori <strong><%= safeCategory %></strong>.
            </p>
            <a href="<%= categoryUrl %>" class="btn ghost">Lihat Semua <%= safeCategory %></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <% if (related && related.length) { %>
    <section class="section container related-section">
      <div class="section-head">
        <div>
          <h2>Produk Serupa</h2>
          <p class="section-subtitle">Pilihan lain yang masih relevan untuk kamu cek</p>
        </div>
      </div>

      <div class="grid-products related-products-grid">
        <% related.forEach((item) => { %>
          <%
            const relatedImage =
              ((item.images && item.images.length > 0) ? item.images[0] : item.image) ||
              "https://via.placeholder.com/800x800?text=Teman+Belanja";
            const relatedPrice = typeof formatRupiah === "function"
              ? formatRupiah(item.price || 0)
              : ("Rp " + Number(item.price || 0).toLocaleString("id-ID"));
          %>

          <article class="card product-card">
            <a href="/produk/<%= item.slug %>" class="product-link" aria-label="Lihat produk <%= item.name %>">
              <div class="product-thumb-wrap">
                <img
                  src="<%= relatedImage %>"
                  alt="<%= item.name %>"
                  loading="lazy"
                />
              </div>

              <div class="product-card-body">
                <% if (item.category) { %>
                  <span class="mini-category"><%= item.category %></span>
                <% } %>

                <h3><%= item.name %></h3>

                <% if (item.shortDesc) { %>
                  <p class="product-short"><%= item.shortDesc %></p>
                <% } %>

                <p class="price"><%= relatedPrice %></p>
              </div>
            </a>

            <a class="btn primary full" href="/produk/<%= item.slug %>">
              Lihat Produk
            </a>
          </article>
        <% }) %>
      </div>
    </section>
  <% } %>

  <div class="mobile-sticky-buy">
    <div class="mobile-sticky-inner">
      <div class="mobile-price-wrap">
        <span class="mobile-price-label">Harga</span>
        <strong><%= safePrice %></strong>
      </div>

      <div class="mobile-buy-actions">
        <% if (hasAffiliate) { %>
          <a
            class="mobile-buy-btn primary"
            target="_blank"
            rel="nofollow sponsored"
            href="/go/<%= safeProduct.id %>"
          >
            Beli
          </a>
        <% } %>

        <a
          class="mobile-buy-btn secondary"
          target="_blank"
          rel="noopener noreferrer"
          href="https://wa.me/6285383481491?text=Halo%20admin%2C%20saya%20ingin%20dibantu%20produk%20ini%3A%20<%= encodeURIComponent(BASE_URL + '/produk/' + safeProduct.slug) %>"
        >
          Admin
        </a>
      </div>
    </div>
  </div>

  <div id="imageLightbox" class="lightbox" onclick="closeLightbox(event)">
    <button class="lightbox-close" type="button" onclick="closeLightbox(event)">×</button>
    <button class="lightbox-nav lightbox-prev" type="button" onclick="prevImage(event)">❮</button>
    <button class="lightbox-nav lightbox-next" type="button" onclick="nextImage(event)">❯</button>

    <div class="lightbox-content" onclick="event.stopPropagation()">
      <img id="lightboxImage" src="" alt="Preview Besar Produk">
    </div>
  </div>

  <script>
    const galleryImages = <%- JSON.stringify(mediaImages || []) %>;
    let currentImageIndex = 0;

    function clearActiveThumb() {
      document.querySelectorAll(".thumb-btn").forEach((btn) => btn.classList.remove("active"));
    }

    function changePreview(src, index = 0, el = null) {
      const container = document.querySelector(".main-media");
      if (!container) return;

      currentImageIndex = index;
      clearActiveThumb();
      if (el) el.classList.add("active");

      container.innerHTML = `
        <img
          id="mainPreview"
          src="${src}"
          alt="Preview Produk"
          onclick="openLightboxFromMain()"
        />
      `;
    }

    function openLightboxFromMain() {
      const mainPreview = document.getElementById("mainPreview");
      if (!mainPreview) return;

      const currentSrc = mainPreview.getAttribute("src");
      const foundIndex = galleryImages.findIndex((img) => img === currentSrc);

      if (foundIndex >= 0) {
        currentImageIndex = foundIndex;
      }

      openLightbox();
    }

    function openLightbox() {
      const lightbox = document.getElementById("imageLightbox");
      const lightboxImage = document.getElementById("lightboxImage");

      if (!lightbox || !lightboxImage || !galleryImages.length) return;

      lightboxImage.src = galleryImages[currentImageIndex] || galleryImages[0];
      lightbox.classList.add("show");
      document.body.style.overflow = "hidden";
    }

    function closeLightbox(event) {
      if (event) event.stopPropagation();

      const lightbox = document.getElementById("imageLightbox");
      if (!lightbox) return;

      lightbox.classList.remove("show");
      document.body.style.overflow = "";
    }

    function updateLightboxImage() {
      const lightboxImage = document.getElementById("lightboxImage");
      if (!lightboxImage || !galleryImages.length) return;

      lightboxImage.src = galleryImages[currentImageIndex];
    }

    function prevImage(event) {
      if (event) event.stopPropagation();
      if (!galleryImages.length) return;

      currentImageIndex = (currentImageIndex - 1 + galleryImages.length) % galleryImages.length;
      updateLightboxImage();
    }

    function nextImage(event) {
      if (event) event.stopPropagation();
      if (!galleryImages.length) return;

      currentImageIndex = (currentImageIndex + 1) % galleryImages.length;
      updateLightboxImage();
    }

    document.addEventListener("keydown", function (e) {
      const lightbox = document.getElementById("imageLightbox");
      const isOpen = lightbox && lightbox.classList.contains("show");

      if (!isOpen) return;

      if (e.key === "Escape") closeLightbox();
      if (e.key === "ArrowLeft") prevImage();
      if (e.key === "ArrowRight") nextImage();
    });
  </script>

  <script type="application/ld+json">
    <%- JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      name: safeName,
      image: mediaImages,
      description: safeDesc || safeShortDesc || safeName,
      category: safeCategory,
      brand: {
        "@type": "Brand",
        name: "Teman Belanja"
      },
      offers: {
        "@type": "Offer",
        priceCurrency: "IDR",
        price: String(safeProduct.price || 0),
        availability: "https://schema.org/InStock",
        url: `${BASE_URL}/produk/${safeProduct.slug || ''}`
      }
    }) %>
  </script>

  <%- include("partials/footer") %>
</body>
</html>
