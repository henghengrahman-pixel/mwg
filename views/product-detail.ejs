<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>

<body>
  <%- include("partials/header") %>

  <%
    const mediaImages = Array.isArray(product.images) && product.images.length
      ? product.images
      : [product.image || 'https://via.placeholder.com/800x800?text=Teman+Belanja'];

    const safeCategory = product.category || 'Produk Pilihan';
    const safeDesc = product.desc || '';
    const safeShortDesc = product.shortDesc || '';
    const categoryUrl = product.categorySlug ? `/kategori/${product.categorySlug}` : '/produk';
  %>

  <section class="section container product-detail-page">

    <!-- 🔥 BREADCRUMB -->
    <nav class="breadcrumb" style="margin-bottom:18px;">
      <a href="/">Beranda</a>
      <span>/</span>
      <a href="/produk">Produk</a>
      <% if (product.categorySlug) { %>
        <span>/</span>
        <a href="<%= categoryUrl %>"><%= safeCategory %></a>
      <% } %>
      <span>/</span>
      <span><%= product.name %></span>
    </nav>

    <div class="product-detail-grid">

      <!-- IMAGE -->
      <div class="product-gallery-card">
        <div class="product-gallery">
          <div class="main-media">
            <img
              id="mainPreview"
              src="<%= mediaImages[0] %>"
              alt="<%= product.name %> - <%= safeCategory %>"
              loading="lazy"
              onclick="openLightboxFromMain()"
            />
          </div>

          <% if (mediaImages.length > 1) { %>
            <div class="thumb-list">
              <% mediaImages.forEach((img, index) => { %>
                <button
                  class="thumb-btn <%= index === 0 ? 'active' : '' %>"
                  onclick='changePreview("<%= img %>", "image", <%= index %>, this)'
                >
                  <img src="<%= img %>" alt="gambar <%= product.name %> <%= index+1 %>">
                </button>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>

      <!-- INFO -->
      <div class="product-info-card">
        <div class="product-info">

          <div class="product-top-meta">
            <a href="<%= categoryUrl %>" class="pill"><%= safeCategory %></a>
            <span class="trust-badge">🔥 Produk Pilihan</span>
          </div>

          <h1 class="product-title"><%= product.name %></h1>

          <p class="price big"><%= formatRupiah(product.price) %></p>

          <% if (safeShortDesc) { %>
            <p class="short-desc"><%= safeShortDesc %></p>
          <% } %>

          <!-- TRUST -->
          <div class="trust-points">
            <span>✅ Link aman</span>
            <span>✅ Banyak dibeli</span>
            <span>✅ Bisa dibantu admin</span>
          </div>

          <!-- CTA -->
          <div class="buy-buttons" style="margin-top:16px;">
            <% if (product.affiliateUrl || product.sourceUrl) { %>
              <a
                class="btn-buy-main"
                target="_blank"
                rel="nofollow sponsored"
                href="/go/<%= product.id %>"
              >
                🛒 Cek Harga Sekarang
              </a>
            <% } %>

            <a
              class="btn-buy-admin"
              target="_blank"
              href="https://wa.me/6285383481491?text=Halo%20admin%20saya%20ingin%20produk%20ini%20<%= encodeURIComponent(BASE_URL + '/produk/' + product.slug) %>"
            >
              💬 Tanya Admin
            </a>
          </div>

          <!-- DESKRIPSI -->
          <div class="product-description">
            <h2>Deskripsi Produk</h2>
            <p style="white-space: pre-line;"><%= safeDesc %></p>
          </div>

          <% if (product.benefits && product.benefits.length) { %>
            <div class="info-box">
              <h3>Kelebihan Produk</h3>
              <ul>
                <% product.benefits.forEach(b => { %>
                  <li><%= b %></li>
                <% }) %>
              </ul>
            </div>
          <% } %>

          <% if (product.specs && product.specs.length) { %>
            <div class="info-box">
              <h3>Spesifikasi</h3>
              <ul>
                <% product.specs.forEach(s => { %>
                  <li><%= s %></li>
                <% }) %>
              </ul>
            </div>
          <% } %>

        </div>
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <% if (related && related.length) { %>
    <section class="section container">
      <div class="section-head">
        <h2>Produk Serupa</h2>
      </div>

      <div class="grid-products">
        <% related.forEach(item => { %>
          <article class="card product-card">
            <a href="/produk/<%= item.slug %>">
              <img
                src="<%= (item.images && item.images[0]) || item.image %>"
                alt="<%= item.name %>"
              >
              <h3><%= item.name %></h3>
              <p class="price"><%= formatRupiah(item.price) %></p>
            </a>
          </article>
        <% }) %>
      </div>
    </section>
  <% } %>

  <!-- SCHEMA -->
  <script type="application/ld+json">
    <%- JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      name: product.name,
      image: mediaImages,
      description: safeDesc || safeShortDesc,
      offers: {
        "@type": "Offer",
        priceCurrency: "IDR",
        price: product.price,
        availability: "https://schema.org/InStock",
        url: `${BASE_URL}/produk/${product.slug}`
      }
    }) %>
  </script>

  <%- include("partials/footer") %>
</body>
</html>
