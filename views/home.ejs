<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>

<body>
  <%- include("partials/header") %>

  <%
    const safeProducts = Array.isArray(products) ? products : [];
    const safeArticles = Array.isArray(articles) ? articles : [];

    const categoryCounts = {};
    safeProducts.forEach((item) => {
      if (item && item.category) {
        const key = String(item.category).trim();
        if (key) categoryCounts[key] = (categoryCounts[key] || 0) + 1;
      }
    });

    const homeCategories = Object.entries(categoryCounts)
      .sort((a, b) => b[1] - a[1])
      .slice(0, 8);
  %>

  <section class="hero">
    <div class="container hero-wrap">
      <div class="hero-content">
        <span class="badge">Rekomendasi Produk & Tips Belanja</span>
        <h1>Teman Belanja</h1>

        <p class="hero-desc">
          Teman Belanja adalah tempat menemukan berbagai rekomendasi barang bagus,
          review singkat produk, serta tips memilih barang yang tepat untuk kebutuhan
          harian, rumah tangga, fashion, dan lainnya.
        </p>

        <div class="hero-actions">
          <a class="btn primary" href="/produk">Lihat Rekomendasi Produk</a>
          <a class="btn ghost" href="/artikel">Baca Artikel</a>
        </div>
      </div>
    </div>
  </section>

  <% if (homeCategories.length > 0) { %>
    <section class="section container" style="padding-top:28px;padding-bottom:10px;">
      <div class="section-head" style="margin-bottom:14px;">
        <div>
          <h2>Kategori Populer</h2>
          <p class="section-subtitle">Pilih kategori produk yang ingin kamu lihat lebih cepat</p>
        </div>
      </div>

      <div style="display:flex;flex-wrap:wrap;gap:10px;">
        <% homeCategories.forEach(([categoryName, total]) => { %>
          <a
            href="/produk?kategori=<%= encodeURIComponent(categoryName) %>"
            class="pill"
            style="text-decoration:none;"
            aria-label="Lihat produk kategori <%= categoryName %>"
          >
            <%= categoryName %> (<%= total %>)
          </a>
        <% }) %>
      </div>
    </section>
  <% } %>

  <% if (safeProducts.length > 0) { %>
    <section class="section container">
      <div class="section-head">
        <div>
          <h2>Produk Rekomendasi</h2>
          <p class="section-subtitle">Pilihan produk menarik yang sedang banyak dicari</p>
        </div>
        <a href="/produk" class="pill" style="text-decoration:none;">Lihat semua</a>
      </div>

      <div class="grid-products">
        <% safeProducts.slice(0, 8).forEach((product) => { %>
          <%
            const coverImage =
              ((product.images && product.images.length > 0) ? product.images[0] : product.image) ||
              "https://via.placeholder.com/800x800?text=Teman+Belanja";

            const safeName = product.name || "Produk Pilihan";
            const safeCategory = product.category || "";
            const safeShortDesc = product.shortDesc || "";
            const safeSuitableFor = product.suitableFor || "";
          %>

          <article class="card product-card">
            <a href="/produk/<%= product.slug %>" class="product-link" aria-label="Lihat detail <%= safeName %>">
              <div class="product-thumb-wrap" style="position:relative;">
                <img
                  src="<%= coverImage %>"
                  alt="<%= safeName %>"
                  loading="lazy"
                />

                <% if (product.isFeatured) { %>
                  <span
                    style="position:absolute;top:10px;left:10px;background:#ff6b00;color:#fff;font-size:12px;padding:6px 10px;border-radius:999px;font-weight:700;box-shadow:0 4px 14px rgba(0,0,0,.12);z-index:2;"
                  >
                    Unggulan
                  </span>
                <% } %>
              </div>

              <div class="product-card-body">
                <% if (safeCategory) { %>
                  <span class="mini-category"><%= safeCategory %></span>
                <% } %>

                <h3><%= safeName %></h3>

                <div class="mini-meta">
                  <span>⭐ Produk</span>
                  <span>•</span>
                  <span>Pilihan</span>
                  <% if (safeSuitableFor) { %>
                    <span>•</span>
                    <span><%= safeSuitableFor %></span>
                  <% } %>
                </div>

                <% if (safeShortDesc) { %>
                  <p class="product-short"><%= safeShortDesc %></p>
                <% } %>

                <% if (product.price) { %>
                  <p class="price"><%= formatRupiah(product.price) %></p>
                <% } %>
              </div>
            </a>

            <a class="btn primary full" href="/produk/<%= product.slug %>">
              Lihat Produk
            </a>
          </article>
        <% }) %>
      </div>
    </section>
  <% } %>

  <section class="section container">
    <div class="home-highlight-grid">
      <div class="home-highlight-card">
        <span class="pill">Belanja Lebih Mudah</span>
        <h3>Produk Pilihan yang Sudah Dirangkum</h3>
        <p>
          Tidak perlu bingung cari satu per satu. Teman Belanja membantu kamu
          menemukan produk menarik yang layak dicek lebih cepat.
        </p>
      </div>

      <div class="home-highlight-card">
        <span class="pill">Link Produk</span>
        <h3>Langsung Cek Harga & Detail</h3>
        <p>
          Setiap rekomendasi dilengkapi tautan pembelian sehingga kamu bisa
          langsung melihat harga terbaru, varian, dan stok produk.
        </p>
      </div>

      <div class="home-highlight-card">
        <span class="pill">Tips Belanja</span>
        <h3>Artikel Ringkas dan Mudah Dipahami</h3>
        <p>
          Selain produk, kamu juga bisa membaca artikel tips belanja supaya lebih
          mudah menentukan pilihan yang cocok dengan kebutuhanmu.
        </p>
      </div>
    </div>
  </section>

  <% if (safeArticles.length > 0) { %>
    <section class="section container">
      <div class="section-head">
        <div>
          <h2>Artikel Terbaru</h2>
          <p class="section-subtitle">Baca tips dan rekomendasi terbaru dari Teman Belanja</p>
        </div>
        <a href="/artikel" class="pill" style="text-decoration:none;">Lihat semua</a>
      </div>

      <div class="grid-articles">
        <% safeArticles.slice(0, 6).forEach((article) => { %>
          <article class="card article-card">
            <a href="/artikel/<%= article.slug %>" aria-label="Baca artikel <%= article.title %>">
              <img
                src="<%= article.cover || 'https://via.placeholder.com/800x450?text=Teman+Belanja' %>"
                alt="<%= article.title %>"
                loading="lazy"
              />
              <h3><%= article.title %></h3>
            </a>

            <% if (article.excerpt) { %>
              <p><%= article.excerpt %></p>
            <% } %>

            <a class="btn ghost full" href="/artikel/<%= article.slug %>">
              Baca Artikel
            </a>
          </article>
        <% }) %>
      </div>
    </section>
  <% } %>

  <section class="section container">
    <div class="site-info">
      <h2>Tentang Teman Belanja</h2>
      <p>
        Teman Belanja membantu kamu menemukan berbagai barang menarik
        yang berguna untuk kebutuhan sehari-hari. Kami merangkum produk
        pilihan yang banyak dicari serta artikel tips belanja yang mudah dipahami.
      </p>
      <p>
        Semua rekomendasi disusun berdasarkan fungsi, kegunaan, dan
        pengalaman pengguna sehingga kamu bisa menemukan barang yang tepat
        dengan lebih mudah.
      </p>
    </div>
  </section>

  <%- include("partials/footer") %>
</body>
</html>
