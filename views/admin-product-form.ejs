<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>

<body>
  <%- include("partials/header") %>

  <section class="section container">
    <div class="admin-box">
      <h1><%= product ? "Edit Produk" : "Tambah Produk" %></h1>

      <form method="post" enctype="multipart/form-data">

        <!-- NAMA -->
        <div class="form-group">
          <label>Nama Produk</label>
          <input type="text" name="name" value="<%= product?.name || '' %>" required>
        </div>

        <!-- HARGA -->
        <div class="form-group">
          <label>Harga</label>
          <input type="number" name="price" value="<%= product?.price || '' %>" required>
        </div>

        <!-- KATEGORI PRODUK -->
        <div class="form-group">
          <label for="category">Kategori Produk</label>
          <select name="category" id="category" required>
            <option value="">Pilih kategori produk</option>
            <option value="Cowok" <%= product?.category === 'Cowok' ? 'selected' : '' %>>Cowok</option>
            <option value="Cewek" <%= product?.category === 'Cewek' ? 'selected' : '' %>>Cewek</option>
            <option value="Rumah Tangga" <%= product?.category === 'Rumah Tangga' ? 'selected' : '' %>>Rumah Tangga</option>
            <option value="Elektronik" <%= product?.category === 'Elektronik' ? 'selected' : '' %>>Elektronik</option>
          </select>
          <small style="display:block;margin-top:6px;opacity:.8;">
            Kategori ini akan dipakai untuk menu atas website seperti Cowok, Cewek, Rumah Tangga, dan Elektronik.
          </small>
        </div>

        <!-- COCOK UNTUK -->
        <div class="form-group">
          <label for="suitableFor">Cocok Untuk</label>
          <select name="suitableFor" id="suitableFor">
            <option value="">Tidak ditampilkan</option>
            <option value="Pria" <%= product?.suitableFor === 'Pria' ? 'selected' : '' %>>Pria</option>
            <option value="Wanita" <%= product?.suitableFor === 'Wanita' ? 'selected' : '' %>>Wanita</option>
            <option value="Pria / Wanita" <%= product?.suitableFor === 'Pria / Wanita' ? 'selected' : '' %>>Pria / Wanita</option>
          </select>
        </div>

        <!-- SHORT DESC -->
        <div class="form-group">
          <label>Deskripsi Singkat</label>
          <textarea name="shortDesc" rows="2"><%= product?.shortDesc || '' %></textarea>
        </div>

        <!-- DESKRIPSI -->
        <div class="form-group">
          <label>Deskripsi Lengkap</label>
          <textarea name="desc" rows="6"><%= product?.desc || '' %></textarea>
        </div>

        <!-- KEYWORD -->
        <div class="form-group">
          <label>Keyword Utama SEO</label>
          <input
            type="text"
            name="focusKeyword"
            value="<%= product?.focusKeyword || '' %>"
            placeholder="tas wanita elegan"
          >
        </div>

        <!-- KELEBIHAN -->
        <div class="form-group">
          <label>Kelebihan Produk (1 baris = 1 poin)</label>
          <textarea name="benefits" rows="4"><%= product?.benefits?.join('\n') || '' %></textarea>
        </div>

        <!-- SPESIFIKASI -->
        <div class="form-group">
          <label>Spesifikasi Produk</label>
          <textarea name="specs" rows="4"><%= product?.specs?.join('\n') || '' %></textarea>
        </div>

        <!-- LINK PRODUK -->
        <div class="form-group">
          <label>Link Produk</label>
          <input
            type="url"
            name="affiliateUrl"
            value="<%= product?.affiliateUrl || '' %>"
            placeholder="https://..."
          >
        </div>

        <!-- SOURCE URL -->
        <div class="form-group">
          <label>Source URL (opsional)</label>
          <input
            type="url"
            name="sourceUrl"
            value="<%= product?.sourceUrl || '' %>"
            placeholder="https://..."
          >
        </div>

        <hr>

        <h3>Foto Produk</h3>

        <!-- LINK FOTO DULU -->
        <div class="form-group">
          <label>Link Foto (1 baris = 1 foto)</label>
          <textarea
            name="imageLinks"
            rows="5"
            placeholder="https://contoh.com/foto1.jpg&#10;https://contoh.com/foto2.jpg"
          ><%= product?.images?.filter(img => !String(img).startsWith('/uploads/')).join('\n') || '' %></textarea>
        </div>

        <!-- UPLOAD FOTO BELAKANG -->
        <div class="form-group">
          <label>Upload Foto (maksimal 7)</label>
          <input type="file" name="imageFiles" accept="image/*" multiple>
          <small style="display:block;margin-top:6px;opacity:.8;">
            Foto upload manual akan diletakkan setelah Link Foto.
          </small>
        </div>

        <% if (product?.images?.length) { %>
          <div class="form-group">
            <label>Foto Saat Ini</label>

            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(110px,1fr));gap:10px;">
              <% product.images.forEach((img, index) => { %>
                <div style="border:1px solid #eee;border-radius:10px;padding:8px;background:#fff;">
                  <img
                    src="<%= img %>"
                    alt="Foto produk <%= index + 1 %>"
                    style="width:100%;height:110px;object-fit:cover;border-radius:8px;"
                  >
                  <div style="font-size:12px;margin-top:6px;word-break:break-word;opacity:.75;">
                    <%= String(img).startsWith('/uploads/') ? 'Upload Manual' : 'Link Foto' %>
                  </div>
                </div>
              <% }) %>
            </div>

            <label style="display:inline-flex;align-items:center;gap:8px;margin-top:12px;">
              <input type="checkbox" name="keepOldImages" checked>
              Pertahankan foto lama
            </label>
          </div>
        <% } %>

        <hr>

        <h3>Video Produk</h3>

        <!-- LINK VIDEO DULU -->
        <div class="form-group">
          <label>Link Video (1 baris = 1 video)</label>
          <textarea
            name="videoLinks"
            rows="4"
            placeholder="https://contoh.com/video1.mp4&#10;https://contoh.com/video2.mp4"
          ><%= product?.videos?.filter(v => !String(v).startsWith('/uploads/')).join('\n') || '' %></textarea>
        </div>

        <!-- UPLOAD VIDEO BELAKANG -->
        <div class="form-group">
          <label>Upload Video (maksimal 3)</label>
          <input type="file" name="videoFiles" accept="video/*" multiple>
        </div>

        <% if (product?.videos?.length) { %>
          <div class="form-group">
            <label>Video Saat Ini</label>

            <div style="display:flex;flex-wrap:wrap;gap:12px;">
              <% product.videos.forEach((v) => { %>
                <div style="border:1px solid #eee;border-radius:10px;padding:8px;background:#fff;">
                  <video
                    src="<%= v %>"
                    controls
                    style="width:220px;max-width:100%;border-radius:8px;"
                  ></video>
                  <div style="font-size:12px;margin-top:6px;opacity:.75;">
                    <%= String(v).startsWith('/uploads/') ? 'Upload Manual' : 'Link Video' %>
                  </div>
                </div>
              <% }) %>
            </div>

            <label style="display:inline-flex;align-items:center;gap:8px;margin-top:12px;">
              <input type="checkbox" name="keepOldVideos" checked>
              Pertahankan video lama
            </label>
          </div>
        <% } %>

        <hr>

        <h3>SEO</h3>

        <div class="form-group">
          <label>Meta Title</label>
          <input type="text" name="metaTitle" value="<%= product?.metaTitle || '' %>">
        </div>

        <div class="form-group">
          <label>Meta Description</label>
          <textarea name="metaDescription" rows="3"><%= product?.metaDescription || '' %></textarea>
        </div>

        <hr>

        <div class="form-group">
          <label style="display:inline-flex;align-items:center;gap:8px;">
            <input type="checkbox" name="isFeatured" <%= product?.isFeatured ? 'checked' : '' %>>
            Produk Unggulan
          </label>
        </div>

        <div class="form-group">
          <label style="display:inline-flex;align-items:center;gap:8px;">
            <input
              type="checkbox"
              name="active"
              <%= product ? (product.active ? 'checked' : '') : 'checked' %>
            >
            Aktif
          </label>
        </div>

        <button type="submit" class="btn primary full">
          Simpan Produk
        </button>

      </form>
    </div>
  </section>

  <%- include("partials/footer") %>
</body>
</html>
