<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>

<body>
  <%- include("partials/header") %>

  <%
    const safeProducts = Array.isArray(products) ? products : [];
    const currentCategory = typeof selectedCategory !== "undefined" ? selectedCategory : "";
    const currentQuery = typeof searchQuery !== "undefined" ? searchQuery : "";
  %>

  <section class="section container" style="padding-top:32px;">
    <div class="breadcrumb" style="margin-bottom:16px;">
      <a href="/">Beranda</a>
      <span>/</span>
      <span>Produk</span>
    </div>

    <div class="section-head" style="align-items:flex-end;gap:16px;flex-wrap:wrap;">
      <div>
        <h1 style="margin:0 0 8px;">Semua Produk</h1>
        <p class="section-subtitle" style="margin:0;">
          Temukan rekomendasi produk pilihan, produk viral, dan barang yang layak kamu cek.
        </p>
      </div>

      <form method="GET" action="/produk" style="display:flex;gap:10px;flex-wrap:wrap;">
        <input
          type="text"
          name="q"
          value="<%= currentQuery %>"
          placeholder="Cari produk..."
          style="padding:12px 14px;border:1px solid #ddd;border-radius:12px;min-width:220px;"
        />

        <% if (currentCategory) { %>
          <input type="hidden" name="kategori" value="<%= currentCategory %>">
        <% } %>

        <button
          type="submit"
          class="btn primary"
          style="border:none;cursor:pointer;"
        >
          Cari
        </button>
      </form>
    </div>
  </section>

  <section class="section container" style="padding-top:0;">
    <% if (safeProducts.length === 0) { %>
      <div class="card" style="padding:28px;text-align:center;">
        <h2 style="margin-top:0;">Produk belum tersedia</h2>
        <p style="color:#666;line-height:1.8;margin-bottom:18px;">
          Saat ini belum ada produk yang cocok dengan filter atau pencarian kamu.
        </p>
        <a href="/produk" class="btn primary">Lihat Semua Produk</a>
      </div>
    <% } else { %>
      <div class="grid-products">
        <% safeProducts.forEach((product) => { %>
          <%
            const coverImage =
              ((product.images && product.images.length > 0) ? product.images[0] : product.image) ||
              "https://via.placeholder.com/800x800?text=Teman+Belanja";

            const safeName = product?.name || "Produk Pilihan";
            const safeCategory = product?.category || "Rekomendasi";
            const safeShortDesc = product?.shortDesc || "Lihat detail lengkap produk ini.";
            const safePrice = typeof formatRupiah === "function"
              ? formatRupiah(product?.price || 0)
              : ("Rp " + Number(product?.price || 0).toLocaleString("id-ID"));
          %>

          <article class="card product-card">
            <a href="/produk/<%= product.slug %>" class="product-link" aria-label="Lihat detail <%= safeName %>">
              <div class="product-thumb-wrap" style="position:relative;">
                <img
                  src="<%= coverImage %>"
                  alt="<%= safeName %>"
                  loading="lazy"
                />

                <% if (product?.isFeatured) { %>
                  <span
                    style="position:absolute;top:10px;left:10px;background:#ff6b00;color:#fff;font-size:12px;padding:6px 10px;border-radius:999px;font-weight:700;box-shadow:0 4px 14px rgba(0,0,0,.12);z-index:2;"
                  >
                    Unggulan
                  </span>
                <% } %>
              </div>

              <div class="product-card-body">
                <span class="mini-category"><%= safeCategory %></span>

                <h3><%= safeName %></h3>

                <div class="mini-meta">
                  <span>⭐ Pilihan</span>
                  <span>•</span>
                  <span>Rekomendasi</span>
                </div>

                <p class="product-short"><%= safeShortDesc %></p>

                <% if (product?.price) { %>
                  <p class="price"><%= safePrice %></p>
                <% } %>
              </div>
            </a>

            <a class="btn primary full" href="/produk/<%= product.slug %>">
              Lihat Produk
            </a>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>

  <%- include("partials/footer") %>
</body>
</html>
