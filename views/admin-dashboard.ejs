<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>
<body>
  <%- include("partials/header") %>

  <section class="section container">
    <h1>Dashboard Admin</h1>

    <div class="grid-products" style="grid-template-columns: repeat(3, 1fr);">
      <div class="card">
        <h3>Total Produk</h3>
        <p class="price big"><%= totalProducts %></p>
      </div>
      <div class="card">
        <h3>Total Artikel</h3>
        <p class="price big"><%= totalArticles %></p>
      </div>
      <div class="card">
        <h3>Total Order</h3>
        <p class="price big"><%= totalOrders %></p>
      </div>
    </div>

    <div style="margin-top:20px; display:flex; gap:12px; flex-wrap:wrap;">
      <a href="/admin/products" class="btn primary">Kelola Produk</a>
      <a href="/admin/articles" class="btn primary">Kelola Artikel</a>
      <a href="/admin/logout" class="btn ghost">Logout</a>
    </div>
  </section>

  <%- include("partials/footer") %>
</body>
</html>
