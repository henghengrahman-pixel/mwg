<%
  const currentPath = typeof path !== "undefined" ? path : "";
%>

<header class="topbar">
  <div class="container nav">
    <a href="/" class="logo" aria-label="Teman Belanja">
      <img src="/LOGO.png" alt="Teman Belanja - Rekomendasi Produk dan Review" loading="eager" />
    </a>

    <nav class="main-menu" aria-label="Navigasi Utama">
      <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Beranda</a>
      <a href="/kategori/cewek" class="<%= currentPath.includes('/kategori/cewek') ? 'active' : '' %>">Cewek</a>
      <a href="/kategori/cowok" class="<%= currentPath.includes('/kategori/cowok') ? 'active' : '' %>">Cowok</a>
      <a href="/kategori/rumah-tangga" class="<%= currentPath.includes('/kategori/rumah-tangga') ? 'active' : '' %>">Rumah Tangga</a>
      <a href="/kategori/elektronik" class="<%= currentPath.includes('/kategori/elektronik') ? 'active' : '' %>">Elektronik</a>
      <a href="/produk" class="<%= currentPath === '/produk' || currentPath.startsWith('/produk/') ? 'active' : '' %>">Produk</a>
      <a href="/artikel" class="<%= currentPath === '/artikel' || currentPath.startsWith('/artikel/') ? 'active' : '' %>">Artikel</a>
    </nav>
  </div>
</header>
