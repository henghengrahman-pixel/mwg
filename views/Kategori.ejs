<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>

<body>
  <%- include("partials/header") %>

  <section class="section container">
    <div class="page-head">
      <nav class="breadcrumb" aria-label="Breadcrumb" style="margin-bottom:14px;">
        <a href="/">Beranda</a>
        <span aria-hidden="true">/</span>
        <span><%= categoryName || "Kategori Produk" %></span>
      </nav>

      <span class="pill">Kategori Produk</span>
      <h1><%= categoryName || "Kategori Produk" %></h1>

      <p class="page-lead">
        Temukan rekomendasi produk
        <strong><%= (categoryName || "kategori ini").toLowerCase() %></strong>
        terbaik di Teman Belanja. Halaman ini berisi pilihan produk yang telah dikurasi
        agar lebih mudah dibandingkan, dilihat, dan dipilih sesuai kebutuhan.
      </p>
    </div>

    <% if (products && products.length) { %>
      <div class="section-head">
        <div>
          <h2>Pilihan Produk <%= categoryName || "Terbaik" %></h2>
          <p class="section-subtitle">
            Total <strong><%= products.length %></strong> produk dalam kategori ini.
          </p>
        </div>
      </div>

      <div class="grid-products products-grid-list">
        <% products.forEach((product) => { %>
          <article class="card product-card">
            <a href="/produk/<%= product.slug %>" class="product-link" aria-label="<%= product.name %>">
              <div class="product-thumb-wrap">
                <img
                  src="<%= product.image || 'https://via.placeholder.com/800x800?text=Teman+Belanja' %>"
                  alt="<%= product.name %> - <%= product.category || categoryName || 'Teman Belanja' %>"
                  loading="lazy"
                >
              </div>

              <div class="product-card-body">
                <span class="mini-category">
                  <%= product.category || categoryName || "Produk Pilihan" %>
                </span>

                <h3><%= product.name %></h3>

                <p class="product-short">
                  <%= product.shortDesc || "Lihat detail produk, review singkat, dan rekomendasi penggunaannya di Teman Belanja." %>
                </p>

                <div class="mini-meta">
                  <% if (product.suitableFor) { %>
                    <span>Cocok untuk: <%= product.suitableFor %></span>
                  <% } else { %>
                    <span>Produk pilihan Teman Belanja</span>
                  <% } %>
                </div>

                <p class="price">
                  <%= typeof formatRupiah === "function" ? formatRupiah(product.price || 0) : ('Rp ' + Number(product.price || 0).toLocaleString('id-ID')) %>
                </p>
              </div>
            </a>

            <a href="/produk/<%= product.slug %>" class="btn primary full">
              Lihat Detail
            </a>
          </article>
        <% }) %>
      </div>

      <div class="site-info" style="margin-top:28px;">
        <h2>Tentang Kategori <%= categoryName || "Produk" %></h2>
        <p>
          Kategori <strong><%= categoryName || "produk" %></strong> di Teman Belanja dibuat
          untuk memudahkan pengunjung menemukan produk yang lebih relevan dalam satu halaman.
          Dengan struktur kategori yang rapi, pengunjung bisa membandingkan pilihan produk lebih cepat,
          sementara mesin pencari juga lebih mudah memahami topik utama halaman ini.
        </p>
        <p>
          Sebelum membeli, pastikan kamu melihat deskripsi produk, gambar, manfaat, spesifikasi,
          dan detail lain di halaman produk. Dengan begitu, kamu bisa memilih barang yang lebih sesuai
          dengan kebutuhan, budget, dan fungsi penggunaan sehari-hari.
        </p>
      </div>
    <% } else { %>
      <div class="card empty-products-state">
        <span class="pill">Belum Ada Produk</span>
        <h2>Produk untuk kategori ini belum tersedia</h2>
        <p>
          Saat ini belum ada produk yang ditampilkan di kategori
          <strong><%= categoryName || "ini" %></strong>.
          Silakan cek kategori lain atau kembali ke halaman produk untuk melihat rekomendasi lainnya.
        </p>

        <div class="empty-actions">
          <a href="/produk" class="btn primary">Lihat Semua Produk</a>
          <a href="/" class="btn ghost">Kembali ke Beranda</a>
        </div>
      </div>
    <% } %>
  </section>

  <%- include("partials/footer") %>
</body>
</html>
