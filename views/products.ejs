<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>

<body>
  <%- include("partials/header") %>

  <section class="section container products-page">
    <div class="page-head products-page-head">
      <div class="page-head-content">
        <span class="pill">Rekomendasi Pilihan</span>
        <h1>Rekomendasi Barang Bagus</h1>
        <p class="page-lead">
          Temukan berbagai rekomendasi barang bagus untuk kebutuhan harian, rumah tangga,
          fashion, dan kategori lainnya. Kami merangkum produk pilihan yang layak dilihat
          berdasarkan fungsi, tampilan, dan nilai pakainya.
        </p>
      </div>
    </div>

    <div class="products-toolbar">
      <form class="searchbar products-searchbar" method="get" action="/produk">
        <input
          type="text"
          name="q"
          placeholder="Cari produk bagus..."
          value="<%= q || '' %>"
          aria-label="Cari produk"
        />
        <button type="submit" class="btn primary">Cari</button>
      </form>

      <div class="products-summary">
        <% if (q) { %>
          <p>Hasil pencarian untuk: <strong><%= q %></strong></p>
        <% } else { %>
          <p>Total rekomendasi: <strong><%= products ? products.length : 0 %></strong> produk</p>
        <% } %>
      </div>
    </div>

    <% if (products && products.length) { %>
      <div class="grid-products products-grid-list">
        <% products.forEach((product) => { %>
          <%
            const coverImage =
              (product.images && product.images.length ? product.images[0] : product.image) ||
              'https://via.placeholder.com/800x800?text=Teman+Belanja';
          %>

          <article class="card product-card">
            <a href="/produk/<%= product.slug %>" class="product-link">
              <div class="product-thumb-wrap">
                <img
                  src="<%= coverImage %>"
                  alt="<%= product.name %>"
                  loading="lazy"
                />

                <% if (product.isFeatured) { %>
                  <span
                    style="position:absolute;top:10px;left:10px;background:#ff6b00;color:#fff;font-size:12px;padding:6px 10px;border-radius:999px;font-weight:600;box-shadow:0 4px 14px rgba(0,0,0,.12);z-index:2;"
                  >
                    Unggulan
                  </span>
                <% } %>
              </div>

              <div class="product-card-body">
                <% if (product.category) { %>
                  <span class="mini-category"><%= product.category %></span>
                <% } %>

                <h3><%= product.name %></h3>

                <div class="mini-meta">
                  <span>⭐ Produk</span>
                  <span>•</span>
                  <span>Pilihan</span>
                  <% if (product.suitableFor) { %>
                    <span>•</span>
                    <span><%= product.suitableFor %></span>
                  <% } %>
                </div>

                <% if (product.shortDesc) { %>
                  <p class="product-short"><%= product.shortDesc %></p>
                <% } %>

                <p class="price"><%= formatRupiah(product.price) %></p>
              </div>
            </a>

            <a class="btn primary full" href="/produk/<%= product.slug %>">
              Lihat Produk
            </a>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state card empty-products-state">
        <span class="pill">Belum ditemukan</span>
        <h2>Produk belum tersedia</h2>
        <p>
          Produk belum tersedia atau kata kunci yang kamu cari belum ditemukan.
          Coba gunakan kata kunci lain yang lebih singkat dan lebih umum.
        </p>

        <div class="empty-actions">
          <a href="/produk" class="btn primary">Lihat Semua Produk</a>
          <a href="/" class="btn ghost">Kembali ke Beranda</a>
        </div>
      </div>
    <% } %>
  </section>

  <%- include("partials/footer") %>
</body>
</html>
