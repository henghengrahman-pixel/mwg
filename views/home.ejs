<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>

<body>
  <%- include("partials/header") %>

  <%
    const safeProducts = Array.isArray(products) ? products : [];
    const safeArticles = Array.isArray(articles) ? articles : [];
  %>

  <!-- HERO PREMIUM -->
  <section class="hero-premium">
    <div class="container hero-grid">
      <div class="hero-text">
        <span class="badge">🔥 PRODUK VIRAL & TERLARIS</span>
        <h1>TEMUKAN PRODUK TERBAIK TANPA RIBET</h1>

        <p>
          Kami sudah pilihkan produk paling laris, paling dicari, dan paling worth it.
          Kamu tinggal lihat, pilih, dan langsung cek detailnya.
        </p>

        <div class="hero-cta">
          <a href="/produk" class="btn primary">Lihat Produk 🔥</a>
          <a href="/artikel" class="btn ghost">Tips & Artikel</a>
        </div>

        <div class="hero-proof">
          <span>✔ Produk pilihan</span>
          <span>✔ Banyak dicari</span>
          <span>✔ Update setiap hari</span>
        </div>
      </div>

      <div class="hero-image">
        <img src="https://via.placeholder.com/500x500?text=Best+Product" alt="Produk Terbaik" />
      </div>
    </div>
  </section>

  <!-- KEUNGGULAN -->
  <section class="section container">
    <div class="grid-3">
      <div class="card">
        <h3>🔥 Produk Terlaris</h3>
        <p>Semua produk sudah dipilih berdasarkan tren dan minat pasar.</p>
      </div>

      <div class="card">
        <h3>⚡ Hemat Waktu</h3>
        <p>Tidak perlu scroll panjang — semua sudah kami rangkum.</p>
      </div>

      <div class="card">
        <h3>💯 Worth It</h3>
        <p>Produk yang direkomendasikan punya value terbaik.</p>
      </div>
    </div>
  </section>

  <!-- PRODUK -->
  <section class="section container">
    <div class="section-head">
      <h2>🔥 PRODUK TERLARIS & PALING DICARI</h2>
    </div>

    <div class="grid-products">
      <% safeProducts.slice(0, 8).forEach((product) => { %>
        <article class="card product-card premium">
          <a href="/produk/<%= product.slug %>">
            <div class="product-img">
              <img src="<%= product.image || 'https://via.placeholder.com/300' %>" />
              <span class="badge-sale">Best Seller</span>
            </div>

            <div class="product-info">
              <h3><%= product.name %></h3>
              <p><%= product.shortDesc || 'Produk pilihan terbaik' %></p>

              <% if (product.price) { %>
                <div class="price"><%= formatRupiah(product.price) %></div>
              <% } %>
            </div>
          </a>

          <a href="/produk/<%= product.slug %>" class="btn primary full">
            Cek Detail & Harga
          </a>
        </article>
      <% }) %>
    </div>
  </section>

  <!-- ARTIKEL -->
  <section class="section container">
    <div class="section-head">
      <h2>📖 TIPS & ARTIKEL TERBARU</h2>
    </div>

    <div class="grid-articles">
      <% safeArticles.slice(0, 4).forEach((article) => { %>
        <article class="card">
          <a href="/artikel/<%= article.slug %>">
            <img src="<%= article.cover || 'https://via.placeholder.com/400x200' %>" />
            <h3><%= article.title %></h3>
          </a>
          <p><%= article.excerpt || '' %></p>
        </article>
      <% }) %>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="container">
      <h2>Jangan Sampai Ketinggalan Produk Bagus 🔥</h2>
      <p>Cek sekarang sebelum kehabisan atau harga naik</p>
      <a href="/produk" class="btn primary">Lihat Semua Produk</a>
    </div>
  </section>

  <!-- SEO TEXT -->
  <section class="section container">
    <h2>Tentang Teman Belanja</h2>
    <p>
      Teman Belanja adalah platform rekomendasi produk terbaik yang membantu kamu menemukan
      barang berkualitas tanpa harus membuang waktu mencari satu per satu.
      Semua produk dipilih berdasarkan tren, kualitas, dan minat pasar.
    </p>
  </section>

  <%- include("partials/footer") %>
</body>
</html>
