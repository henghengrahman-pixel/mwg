<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>

<body>
  <%- include("partials/header") %>

  <%
    const safeProducts = Array.isArray(products) ? products : [];
    const safeArticles = Array.isArray(articles) ? articles : [];

    const categoryCounts = {};
    safeProducts.forEach((item) => {
      if (item && item.category) {
        const key = String(item.category).trim();
        if (key) categoryCounts[key] = (categoryCounts[key] || 0) + 1;
      }
    });

    const homeCategories = Object.entries(categoryCounts)
      .sort((a, b) => b[1] - a[1])
      .slice(0, 8);

    const featuredProducts = safeProducts.filter((item) => item && item.isFeatured);
    const heroProducts = featuredProducts.length ? featuredProducts.slice(0, 4) : safeProducts.slice(0, 4);
  %>

  <section class="hero">
    <div class="container hero-wrap">
      <div class="hero-content">
        <span class="badge">Rekomendasi Produk Viral • Affiliate Shopee</span>
        <h1>Teman Belanja</h1>

        <p class="hero-desc">
          Temukan rekomendasi produk menarik, barang viral, fashion, kebutuhan harian,
          dan pilihan belanja yang layak dicek. Kami merangkum produk pilihan supaya kamu
          lebih cepat menemukan barang bagus, lalu langsung cek harga, promo, dan review di Shopee.
        </p>

        <div class="hero-actions">
          <a class="btn primary" href="/produk">Lihat Produk Rekomendasi</a>
          <a class="btn ghost" href="/artikel">Baca Artikel Pilihan</a>
        </div>

        <% if (heroProducts.length > 0) { %>
          <div class="trust-points" style="margin-top:18px;">
            <span>🔥 Produk pilihan harian</span>
            <span>🛒 Langsung cek di Shopee</span>
            <span>💬 Bisa lihat review pembeli</span>
            <span>🎁 Cek promo & harga terbaru</span>
          </div>
        <% } %>
      </div>
    </div>
  </section>

  <% if (homeCategories.length > 0) { %>
    <section class="section container" style="padding-top:28px;padding-bottom:8px;">
      <div class="section-head" style="margin-bottom:14px;">
        <div>
          <h2>Kategori Populer</h2>
          <p class="section-subtitle">Pilih kategori produk yang sedang banyak dicari</p>
        </div>
      </div>

      <div style="display:flex;flex-wrap:wrap;gap:10px;">
        <% homeCategories.forEach(([categoryName, total]) => { %>
          <a
            href="/produk?kategori=<%= encodeURIComponent(categoryName) %>"
            class="pill"
            style="text-decoration:none;"
            aria-label="Lihat produk kategori <%= categoryName %>"
          >
            <%= categoryName %> (<%= total %>)
          </a>
        <% }) %>
      </div>
    </section>
  <% } %>

  <% if (safeProducts.length > 0) { %>
    <section class="section container">
      <div class="section-head">
        <div>
          <h2>Produk Rekomendasi</h2>
          <p class="section-subtitle">Pilihan produk yang layak dicek harga, promo, dan reviewnya</p>
        </div>
        <a href="/produk" class="pill" style="text-decoration:none;">Lihat semua</a>
      </div>

      <div class="grid-products">
        <% safeProducts.slice(0, 8).forEach((product) => { %>
          <%
            const coverImage =
              ((product.images && product.images.length > 0) ? product.images[0] : product.image) ||
              "https://via.placeholder.com/800x800?text=Teman+Belanja";

            const safeName = product.name || "Produk Pilihan";
            const safeCategory = product.category || "";
            const safeShortDesc = product.shortDesc || "";
            const safeSuitableFor = product.suitableFor || "";
          %>

          <article class="card product-card">
            <a href="/produk/<%= product.slug %>" class="product-link" aria-label="Lihat detail <%= safeName %>">
              <div class="product-thumb-wrap" style="position:relative;">
                <img
                  src="<%= coverImage %>"
                  alt="<%= safeName %>"
                  loading="lazy"
                />

                <% if (product.isFeatured) { %>
                  <span
                    style="position:absolute;top:10px;left:10px;background:#ff6b00;color:#fff;font-size:12px;padding:6px 10px;border-radius:999px;font-weight:700;box-shadow:0 4px 14px rgba(0,0,0,.12);z-index:2;"
                  >
                    Unggulan
                  </span>
                <% } %>
              </div>

              <div class="product-card-body">
                <% if (safeCategory) { %>
                  <span class="mini-category"><%= safeCategory %></span>
                <% } %>

                <h3><%= safeName %></h3>

                <div class="mini-meta">
                  <span>🛒 Cek Shopee</span>
                  <span>•</span>
                  <span>Review Pembeli</span>
                  <% if (safeSuitableFor) { %>
                    <span>•</span>
                    <span><%= safeSuitableFor %></span>
                  <% } %>
                </div>

                <% if (safeShortDesc) { %>
                  <p class="product-short"><%= safeShortDesc %></p>
                <% } %>

                <% if (product.price) { %>
                  <p class="price"><%= formatRupiah(product.price) %></p>
                <% } %>
              </div>
            </a>

            <a class="btn primary full" href="/produk/<%= product.slug %>">
              Lihat Detail
            </a>
          </article>
        <% }) %>
      </div>
    </section>
  <% } %>

  <section class="section container">
    <div class="home-highlight-grid">
      <div class="home-highlight-card">
        <span class="pill">Produk Pilihan</span>
        <h3>Rekomendasi yang Sudah Dirangkum</h3>
        <p>
          Tidak perlu capek cari satu-satu. Teman Belanja membantu merangkum produk
          yang sedang dicari supaya kamu lebih cepat menemukan pilihan yang menarik.
        </p>
      </div>

      <div class="home-highlight-card">
        <span class="pill">Cek Shopee</span>
        <h3>Langsung Lihat Harga, Promo, dan Review</h3>
        <p>
          Setiap produk bisa langsung kamu cek ke marketplace untuk melihat harga terbaru,
          varian, stok, diskon, dan ulasan pembeli sebelum memutuskan beli.
        </p>
      </div>

      <div class="home-highlight-card">
        <span class="pill">SEO & Artikel</span>
        <h3>Tips Belanja Ringkas dan Mudah Dipahami</h3>
        <p>
          Selain produk, kamu juga bisa baca artikel rekomendasi dan tips belanja
          supaya lebih gampang memilih barang yang cocok dengan kebutuhan.
        </p>
      </div>
    </div>
  </section>

  <% if (safeArticles.length > 0) { %>
    <section class="section container">
      <div class="section-head">
        <div>
          <h2>Artikel Terbaru</h2>
          <p class="section-subtitle">Baca rekomendasi produk, tips belanja, dan inspirasi pilihan terbaik</p>
        </div>
        <a href="/artikel" class="pill" style="text-decoration:none;">Lihat semua</a>
      </div>

      <div class="grid-articles">
        <% safeArticles.slice(0, 6).forEach((article) => { %>
          <article class="card article-card">
            <a href="/artikel/<%= article.slug %>" aria-label="Baca artikel <%= article.title %>">
              <img
                src="<%= article.cover || 'https://via.placeholder.com/800x450?text=Teman+Belanja' %>"
                alt="<%= article.title %>"
                loading="lazy"
              />
              <h3><%= article.title %></h3>
            </a>

            <% if (article.excerpt) { %>
              <p><%= article.excerpt %></p>
            <% } %>

            <a class="btn ghost full" href="/artikel/<%= article.slug %>">
              Baca Artikel
            </a>
          </article>
        <% }) %>
      </div>
    </section>
  <% } %>

  <% if (safeProducts.length > 0) { %>
    <section class="section container">
      <div class="site-info">
        <h2>Kenapa cek produk lewat Teman Belanja?</h2>
        <p>
          Teman Belanja membantu kamu menemukan produk yang sedang ramai, menarik,
          dan layak dipertimbangkan tanpa harus muter-muter cari sendiri.
        </p>
        <p>
          Kami merangkum rekomendasi produk dan artikel yang relevan, lalu mengarahkan kamu
          untuk cek detail lengkap di Shopee seperti harga terbaru, variasi, stok, dan review pembeli.
        </p>
        <p>
          Jadi alurnya lebih simpel: temukan produk di Teman Belanja, lihat ringkasannya,
          lalu lanjut cek marketplace untuk keputusan belanja yang lebih aman dan nyaman.
        </p>
      </div>
    </section>
  <% } %>

  <%- include("partials/footer") %>
</body>
</html>
