<!DOCTYPE html>
<html lang="id">
<%- include("partials/head") %>

<body>
  <%- include("partials/header") %>

  <%
    const mediaImages = Array.isArray(product.images) && product.images.length
      ? product.images.filter(Boolean)
      : [product.image || "https://via.placeholder.com/800x800?text=Teman+Belanja"];

    const productVideos = Array.isArray(product.videos) ? product.videos.filter(Boolean) : [];
    const hasVideo = productVideos.length > 0;

    const safeCategory = product.category || "Produk Pilihan";
    const safeDesc = product.desc || "Produk ini direkomendasikan karena kualitasnya baik dan layak dipertimbangkan.";
    const safeShortDesc = product.shortDesc || "";
    const safeSuitableFor = product.suitableFor || "";
    const categoryUrl = product.categorySlug ? `/kategori/${product.categorySlug}` : "/produk";
    const safePrice = typeof formatRupiah === "function"
      ? formatRupiah(product.price || 0)
      : ("Rp " + Number(product.price || 0).toLocaleString("id-ID"));
  %>

  <section class="section container product-detail-page">
    <nav class="breadcrumb" aria-label="Breadcrumb" style="margin-bottom:18px;">
      <a href="/">Beranda</a>
      <span>/</span>
      <a href="/produk">Produk</a>
      <% if (product.categorySlug) { %>
        <span>/</span>
        <a href="<%= categoryUrl %>"><%= safeCategory %></a>
      <% } %>
      <span>/</span>
      <span><%= product.name %></span>
    </nav>

    <div class="product-detail-grid">
      <!-- GALLERY -->
      <div class="product-gallery-card">
        <div class="product-gallery">
          <div class="main-media">
            <img
              id="mainPreview"
              src="<%= mediaImages[0] %>"
              alt="<%= product.name %> - <%= safeCategory %>"
              loading="lazy"
            />
          </div>

          <% if (mediaImages.length > 1 || hasVideo) { %>
            <div class="thumb-list">
              <% mediaImages.forEach((img, index) => { %>
                <button
                  type="button"
                  class="thumb-btn <%= index === 0 ? 'active' : '' %>"
                  onclick='changePreview(<%- JSON.stringify(img) %>, "image", <%= index %>, this)'
                >
                  <img src="<%= img %>" loading="lazy" />
                </button>
              <% }) %>

              <% productVideos.forEach((video, index) => { %>
                <button
                  type="button"
                  class="thumb-btn video-thumb"
                  onclick='changePreview(<%- JSON.stringify(video) %>, "video", <%= index %>, this)'
                >
                  <span>VIDEO</span>
                </button>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>

      <!-- INFO -->
      <div class="product-info-card">
        <div class="product-info">

          <div class="product-top-meta">
            <a href="<%= categoryUrl %>" class="pill"><%= safeCategory %></a>
            <span class="trust-badge">Produk Pilihan</span>
          </div>

          <h1 class="product-title"><%= product.name %></h1>

          <div class="product-meta-row">
            <span>⭐ Rekomendasi</span>
            <span class="meta-divider">•</span>
            <span>Link Aman</span>
            <span class="meta-divider">•</span>
            <span>Siap Dicek</span>
          </div>

          <p class="price big"><%= safePrice %></p>

          <% if (safeShortDesc) { %>
            <p class="short-desc"><%= safeShortDesc %></p>
          <% } %>

          <div class="quick-info-grid">
            <div class="quick-info-item">
              <span class="label">Kategori</span>
              <strong><%= safeCategory %></strong>
            </div>

            <% if (safeSuitableFor) { %>
              <div class="quick-info-item">
                <span class="label">Cocok Untuk</span>
                <strong><%= safeSuitableFor %></strong>
              </div>
            <% } %>

            <div class="quick-info-item">
              <span class="label">Pembelian</span>
              <strong>Online / COD</strong>
            </div>

            <div class="quick-info-item">
              <span class="label">Status</span>
              <strong>Ready Siap Kirim</strong>
            </div>
          </div>

          <div class="trust-points">
            <span>✅ Link aman</span>
            <span>✅ Produk pilihan</span>
            <span>✅ Bisa dibantu admin</span>
          </div>

          <p class="cta-note">
            Kamu bisa beli langsung lewat Shopee atau minta bantuan admin untuk checkout.
          </p>

          <div class="buy-buttons">
            <% if (product.affiliateUrl || product.sourceUrl) { %>
              <a
                class="btn-buy-main"
                target="_blank"
                rel="nofollow sponsored"
                href="/go/<%= product.id %>"
              >
                🛒 Beli di Shopee
              </a>
            <% } %>

            <a
              class="btn-buy-admin"
              target="_blank"
              rel="noopener noreferrer"
              href="https://wa.me/6285383481491?text=Halo%20admin%2C%20saya%20ingin%20dibantu%20checkout%20produk%20ini%3A%20<%= encodeURIComponent(BASE_URL + '/produk/' + product.slug) %>"
            >
              💬 Minta Bantuan Checkout
            </a>
          </div>

          <div class="product-description">
            <h2>Deskripsi Produk</h2>
            <p><%= safeDesc %></p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- MOBILE STICKY -->
  <div class="mobile-sticky-buy">
    <div class="mobile-sticky-inner">
      <div class="mobile-price-wrap">
        <span class="mobile-price-label">Harga</span>
        <strong><%= safePrice %></strong>
      </div>

      <div class="mobile-buy-actions">
        <% if (product.affiliateUrl || product.sourceUrl) { %>
          <a
            class="mobile-buy-btn primary"
            target="_blank"
            rel="nofollow sponsored"
            href="/go/<%= product.id %>"
          >
            Beli Shopee
          </a>
        <% } %>

        <a
          class="mobile-buy-btn secondary"
          target="_blank"
          rel="noopener noreferrer"
          href="https://wa.me/6285383481491?text=Halo%20admin%2C%20saya%20ingin%20dibantu%20checkout%20produk%20ini%3A%20<%= encodeURIComponent(BASE_URL + '/produk/' + product.slug) %>"
        >
          Bantuan
        </a>
      </div>
    </div>
  </div>

  <%- include("partials/footer") %>
</body>
</html>
